# Copy to `.env` (git-ignored) and fill in real values.
# Loaded by dotenvy at the top of config/runtime.exs.

# PostgreSQL connection (used in prod; dev/test use config/{dev,test}.exs).
# Format: ecto://USER:PASS@HOST/DATABASE
DATABASE_URL=ecto://postgres:postgres@localhost/api_harness_dev

# OpenAI API key for the gpt-4o-mini chat + text-embedding-3-small embeddings.
OPENAI_API_KEY=sk-...

# Secret used to sign/verify JWTs (HS256). Use a random 64+ char string.
JWT_SECRET=

# Phoenix endpoint secret. Generate with: mix phx.gen.secret
SECRET_KEY_BASE=
